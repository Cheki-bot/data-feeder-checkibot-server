# ============================================
# .env.example - Environment Variables Template
# ============================================
# Copy this file to .env and update with your actual values
# Command: cp .env.example .env

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
# In production, use specific domains: https://yourdomain.com,https://app.yourdomain.com
ALLOW_ORIGINS=*

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================
# Admin user credentials (created automatically on server startup)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-super-secure-admin-password-min-16-chars

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars

# ============================================
# MONGODB CONFIGURATION
# ============================================
# MongoDB Atlas (production) - Remove credentials from URI!
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
# For local development:
# MONGO_URI=mongodb://localhost:27017/

MONGO_DB_NAME=your_database_name

# ============================================
# LLM CONFIGURATION (OpenAI)
# ============================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-nano
LLM_EMB_MODEL=text-embedding-3-small
# Get your API key from: https://platform.openai.com/api-keys
LLM_API_KEY=your-openai-api-key-here-starts-with-sk-proj
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_CONTEXT_LENGTH=32768

# ============================================
# CHROMA VECTOR DATABASE
# ============================================
CHROMA_PERSIST_DIRECTORY=chroma_db

# ============================================
# GOOGLE DRIVE CONFIGURATION
# ============================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_DATA_FILENAME=database.json
GOOGLE_FOLDER_ID=your-google-drive-folder-id-here

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Get your bot token from: @BotFather on Telegram
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
CHEKIBOT_API=https://api.example.com/api/chatbot/webhook
